<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".DetailActivity">

    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bill Detail"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#166D08"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textMonthDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Month:"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="40dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/textTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textUnitDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unit Used:"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/textMonthDetail"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textRebateDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rebate:"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/textUnitDetail"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textTotalDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total Charges:"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/textRebateDetail"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textFinalDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Final Cost:"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#166D08"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/textTotalDetail"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/btnUpdate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="UPDATE"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#FFC800"
        android:layout_marginTop="30dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toBottomOf="@id/textFinalDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDelete"/>

    <Button
        android:id="@+id/btnDelete"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="DELETE"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#166D08"
        android:layout_marginTop="30dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/textFinalDetail"
        app:layout_constraintStart_toEndOf="@id/btnUpdate"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>